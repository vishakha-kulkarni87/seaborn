regplot (Regression Plot)

regplot shows the relationship between two variables using:
Scatter plot (data points)
Regression line (trend line)
=======================================================

import seaborn as sns
import matplotlib.pyplot as plt

df = sns.load_dataset("iris")
df.head()
-------------------------------------------
sns.regplot(x="petal_length", y="petal_width", data=df)

plt.show()
-----------------------------------------------------------
sns.regplot(x="petal_length", y="petal_width", data=df, ci=100)
--------------------------------------------------------------------

sns.regplot(x="petal_length", y="petal_width", data=df, ci=None)
------------------------------------------------------------------
sns.regplot(x="petal_length", y="petal_width", data=df, order=7)
---------------------------------------------------------------------
sns.regplot(
    x="petal_length",
    y="petal_width",
    data=df,
    scatter_kws={"s": 50},   # size of dots
    line_kws={"color": "red"}
)

plt.show()
